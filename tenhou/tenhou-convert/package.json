  "devDependencies": {
    "mocha": "^11.7.1",
    "nyc": "^17.1.0"
  },
  "dependencies": {
    "@kobalab/tenhou-log": "file:../tenhou-log-1.3.1",
    "@kobalab/tenhou-url-log": "file:../tenhou-url-log-1.0.4/tenhou-url-log-1.0.4",
